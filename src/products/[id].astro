<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-bold tracking-wider text-gray-900">YITUMU</a>
    <a href="/" class="text-sm text-gray-500 hover:text-black transition">← Back to Home</a>
  </div>
</header>

<main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 bg-white border border-gray-100 p-8 rounded-3xl shadow-sm">
    <div class="aspect-square w-full rounded-2xl overflow-hidden bg-gray-50 border border-gray-100 flex items-center justify-center">
      <img src={product.image} alt={product.title} class="w-full h-full object-cover" />
    </div>
    <div class="flex flex-col justify-between">
      <div>
        <span class="text-xs font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-3 py-1 rounded-full">{product.category}</span>
        <h1 class="text-2xl sm:text-3xl font-black text-gray-950 mt-4 mb-2 tracking-tight">{product.title}</h1>
        <div class="flex items-center gap-4 mb-6">
          <p class="text-xs font-mono text-gray-400">Model: {product.model}</p>
          <p class="text-sm font-bold text-gray-900 bg-gray-100 px-3 py-1 rounded">MSRP: ${product.msrp}</p>
        </div>
        <p class="text-md text-gray-600 mb-8 leading-relaxed">{product.description}</p>
        <h3 class="text-sm font-bold text-gray-950 mb-3">Key Highlights</h3>
        <ul class="space-y-2 mb-8">
          {product.features.map((feat) => (
            <li class="text-sm text-gray-600 flex items-center">
              <span class="mr-3 text-green-500 font-bold">✓</span> {feat}
            </li>
          ))}
        </ul>
      </div>
      <div class="border-t border-gray-100 pt-6">
        <a href={product.platforms.shein} target="_blank" class="w-full block text-center bg-black text-white py-3.5 rounded-xl font-semibold hover:bg-gray-800 transition shadow-sm">
          Buy on SHEIN Store
        </a>
      </div>
    </div>
  </div>
</main>