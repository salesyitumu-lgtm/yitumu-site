---
import products from '../data/products.json';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>YITUMU Official | Premium Product Showcase</title>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans">
    
    <!-- 导航栏 -->
    <header class="bg-white border-b border-gray-100 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <div class="text-xl font-bold tracking-wider text-gray-900">YITUMU</div>
        <nav class="flex space-x-8">
          <a href="#" class="text-black font-semibold">Home</a>
          <a href="#products" class="text-gray-500 hover:text-black transition">Products</a>
        </nav>
      </div>
    </header>

    <!-- 头部 Banner -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
      <h1 class="text-4xl sm:text-5xl font-black text-gray-950 tracking-tight mb-4">
        YITUMU Official Showcase
      </h1>
      <p class="text-md text-gray-500 max-w-xl mx-auto mb-12">
        Explore our latest innovations in smart automotive accessories and portable smart devices.
      </p>

      <!-- 产品网格区域 -->
      <section id="products" class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left max-w-4xl mx-auto">
        {products.map((product) => (
          <div class="bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition flex flex-col justify-between">
            <div>
              <!-- 产品图片超清展示区 -->
<div class="bg-white aspect-square w-full overflow-hidden flex items-center justify-center border-b border-gray-50">
  <img 
    src={product.image} 
    alt={product.title} 
    class="w-full h-full object-cover hover:scale-105 transition duration-500"
    loading="lazy"
  />
</div>
              
              <!-- 文字详情区 -->
              <div class="p-6 pb-0">
                <div class="text-xs font-bold uppercase tracking-wider text-blue-600 mb-2">{product.category}</div>
                <h2 class="text-xl font-bold text-gray-950 mb-2">{product.title}</h2>
                <p class="text-sm text-gray-500 mb-4 leading-relaxed">{product.description}</p>
                
                <ul class="space-y-1.5 mb-6">
                  {product.features.map((feat) => (
                    <li class="text-xs text-gray-600 flex items-center">
                      <span class="mr-2 text-green-500 font-bold">✓</span> {feat}
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <!-- 卡片底部动作条 -->
            <div class="p-6 pt-0">
              <div class="border-t border-gray-50 pt-4 flex items-center justify-between">
                <span class="text-xs font-mono text-gray-400">Model: {product.model}</span>
                <div class="flex space-x-2">
                  {product.platforms.shein && (
                    <a href={product.platforms.shein} target="_blank" class="text-xs bg-black text-white px-4 py-2 rounded-lg font-medium hover:bg-gray-850 transition">
                      Buy on SHEIN
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))}
      </section>
    </main>

  </body>
</html>