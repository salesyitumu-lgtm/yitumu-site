---
import products from '../data/products.json';
---
<html lang="en">
  <head><meta charset="utf-8" /><title>YITUMU Official</title></head>
  <body class="bg-gray-50">
    <section class="grid grid-cols-2 lg:grid-cols-6 gap-4 p-8">
      {products.map((product) => (
        <div class="bg-white p-4 rounded-xl shadow-sm">
          <img src={product.image} alt={product.title} class="w-full aspect-square object-cover" />
          <h2 class="font-bold text-sm mt-2"><a href={`/products/${product.id}`}>{product.title}</a></h2>
          <p class="text-xs font-bold mt-1">MSRP: ${product.msrp}</p>
        </div>
      ))}
    </section>
  </body>
</html>