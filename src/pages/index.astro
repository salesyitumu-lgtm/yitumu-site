<!-- 导航栏 -->
<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <div class="text-xl font-bold tracking-wider text-gray-900">YITUMU</div>
    <nav class="flex space-x-6 text-sm">
      <a href="/" class="text-black font-semibold">Home</a>
      <a href="#products" class="text-gray-500 hover:text-black transition">Products</a>
      <a href="/contact" class="text-gray-500 hover:text-black transition">Contact</a>
    </nav>
  </div>
</header>

<main class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="text-center max-w-2xl mx-auto mb-12">
    <h1 class="text-3xl sm:text-5xl font-black text-gray-950 tracking-tight mb-4">
      YITUMU Official Showcase
    </h1>
    <p class="text-sm sm:text-base text-gray-500 leading-relaxed">
      Explore our premium innovations in smart automotive accessories, portable cooling, and smart home lighting.
    </p>
  </div>

  <!-- 6列自适应产品网格 -->
  <section id="products" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 sm:gap-4 lg:gap-5">
    {products.map((product) => (
      <div class="bg-white border border-gray-100 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition duration-300 flex flex-col justify-between h-full">
        <div class="flex flex-col">
          <div class="bg-white aspect-square w-full overflow-hidden flex items-center justify-center border-b border-gray-100 relative">
            <img 
              src={product.image} 
              alt={product.title} 
              class="w-full h-full object-cover hover:scale-105 transition duration-500"
              loading="lazy"
              onerror="this.src='https://placehold.co/400x400/f3f4f6/9ca3af?text=YITUMU'"
            />
          </div>
          <div class="p-3 sm:p-4">
            <span class="inline-block text-[10px] font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-2 py-0.5 rounded mb-2">
              {product.category}
            </span>
            <h2 class="text-xs sm:text-sm font-bold text-gray-950 mb-1.5 leading-snug line-clamp-2 min-h-[2.5rem] hover:text-blue-600 transition">
              <a href={`/products/${product.id}`}>{product.title}</a>
            </h2>
            <ul class="space-y-1 mb-3">
              {product.features.map((feat) => (
                <li class="text-[11px] text-gray-500 flex items-center truncate">
                  <span class="mr-1 text-green-500 font-bold">✓</span> {feat}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="p-3 sm:p-4 pt-0">
          <div class="border-t border-gray-50 pt-3 flex flex-col gap-2">
            <div class="flex items-center justify-between">
              <span class="text-[10px] font-mono text-gray-400 truncate">Model: {product.model}</span>
              <span class="text-[11px] font-bold text-gray-900">MSRP: ${product.msrp}</span>
            </div>
            {product.platforms.shein && (
              <a href={product.platforms.shein} target="_blank" class="w-full block text-center text-[11px] bg-black text-white py-2 rounded-lg font-medium hover:bg-gray-800 transition duration-200">
                Buy on SHEIN
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </section>
</main>