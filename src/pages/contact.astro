---
// 联系我们页面
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Contact Us | YITUMU B2B & Wholesale</title>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans">
    
    <!-- 导航栏 -->
    <header class="bg-white border-b border-gray-100 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-wider text-gray-900">YITUMU</a>
        <nav class="flex space-x-8">
          <a href="/" class="text-gray-500 hover:text-black transition">Home</a>
          <a href="/#products" class="text-gray-500 hover:text-black transition">Products</a>
          <a href="/contact" class="text-black font-semibold">Contact</a>
        </nav>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-black text-gray-950 mb-4">Get in Touch</h1>
        <p class="text-gray-500">For wholesale inquiries, B2B partnerships, or OEM/ODM support.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
        <!-- 侧边信息 -->
        <div class="space-y-8 flex flex-col justify-between">
          <div>
            <h3 class="text-lg font-bold mb-2">Our Office</h3>
            <p class="text-sm text-gray-500 leading-relaxed">
              Premium Automotive & Electronic Solutions<br/>
              High-quality manufacturing standards (CE, RoHS compliant).
            </p>
          </div>
          <div>
            <h3 class="text-lg font-bold mb-2">Email Us Directly</h3>
            <p class="text-sm text-blue-600 font-mono font-semibold">contact@yitumuglobal.com</p>
          </div>
          <div class="pt-6 border-t border-gray-50">
            <span class="text-xs bg-green-50 text-green-700 px-3 py-1 rounded-full font-bold">✓ 24H Response Guarantee</span>
          </div>
        </div>

        <!-- 询盘表单 -->
        <form class="space-y-4">
          <div>
            <label class="block text-xs font-bold uppercase text-gray-400 mb-1">Your Name</label>
            <input type="text" placeholder="John Doe" class="w-full bg-gray-50 border border-gray-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-black/5" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase text-gray-400 mb-1">Business Email</label>
            <input type="email" placeholder="john@company.com" class="w-full bg-gray-50 border border-gray-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-black/5" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase text-gray-400 mb-1">Message</label>
            <textarea rows="4" placeholder="Tell us about your wholesale needs..." class="w-full bg-gray-50 border border-gray-100 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-black/5"></textarea>
          </div>
          <button type="button" class="w-full bg-black text-white py-3 rounded-xl font-bold hover:bg-gray-850 transition">
            Send Inquiry
          </button>
        </form>
      </div>
    </main>
  </body>
</html>